#!/bin/bash

DOTFILES_DIR="$HOME/dotfiles"

# カラー定義
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

SEP="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

step() {
    printf "  ${CYAN}%-28s${RESET}" "$1..."
}

ok() {
    printf "${GREEN}✓${RESET}\n"
}

fail() {
    printf "${YELLOW}✗ $1${RESET}\n"
}

echo ""
echo -e "${BOLD} dotupdate${RESET}"
echo "$SEP"

# git pull
step "pulling latest"
if git -C "$DOTFILES_DIR" pull -q 2>/dev/null; then
    ok
else
    fail "git pull failed"
fi

# tmux
step "reloading tmux"
if tmux source-file ~/.tmux.conf 2>/dev/null; then
    ok
else
    fail "tmux not running"
fi

# zsh
step "reloading zsh"
if [ -f ~/.zshrc ]; then
    ok
    echo ""
    echo "$SEP"
    echo -e "${GREEN}${BOLD} All up to date!${RESET}"
    echo ""
    exec zsh
else
    fail "~/.zshrc not found"
fi
